# Repository root — used by `docker compose` (see docker-compose.yml).
# Copy to `.env` in this directory: cp .env.example .env

SECRET_KEY=change-me-to-a-long-random-string

# JSON list — include origins you use (Expo, Vite dev, admin behind nginx on :8080).
# If you open Expo Web against a Bonjour host, add it too, e.g.:
#   "http://helios.local:8081"
CORS_ORIGINS=["http://localhost:8081","http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# Optional: USDA FoodData Central
USDA_API_KEY=

# ── Local dev seed (backend entrypoint runs if email + password are non-empty) ─
# `docker-compose.yml` sets the same defaults, so copying this file is optional for seeding.
# To disable: set SEED_ADMIN_EMAIL= (empty) in `.env` or remove the SEED_* lines from compose.
# WARNING: Only for local development. Remove or blank in shared/prod envs.
# On Render / production: prefer blank SEED_ADMIN_* **or** set SKIP_SEED_ADMIN_ON_START=1 so
# every deploy does not run seed_admin (admin already exists).
# SKIP_SEED_ADMIN_ON_START=1
SEED_ADMIN_EMAIL=barclay@distinctpixel.com
SEED_ADMIN_PASSWORD=food11
SEED_ADMIN_DISPLAY_NAME=barclay
# Spring Fiesta + sample posts: run `make seed` after `docker compose up` (see AGENTS.md).

# Post media: local disk under ./data (mounted /media/data in Docker). S3 reserved for production.
STORAGE_BACKEND=local
# S3_BUCKET=
# S3_REGION=
# BLIP_DISABLE=false
# Docker Compose sets HF_HOME to ./data/hf-cache (bind mount) so BLIP weights are not re-downloaded on every container start.
