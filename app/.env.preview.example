# Copy to ``.env.preview`` (gitignored) for builds that should talk to hosted API (e.g. Render).
# Then start Metro with: ``npm run start:preview`` or ``./scripts/run-with-env .env.preview``
#
#   cp .env.preview.example .env.preview
#
# Use your real Render (or staging) origin + ``/api/v1``:
EXPO_PUBLIC_API_URL=https://your-service.onrender.com/api/v1
