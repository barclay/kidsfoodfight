#!/usr/bin/env bash
# Start Metro with variables from a dotenv file (e.g. Render preview URL).
# Usage from app/:  ./scripts/run-with-env .env.preview
#                       ./scripts/run-with-env .env.preview -- --clear
#
# Loads optional ``.env`` first, then the given file so preview/staging wins for
# duplicate keys. Restart Metro after switching; reload the app (``--clear`` if
# the bundle looks cached).
set -euo pipefail
APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

if [[ $# -lt 1 ]]; then
  echo "usage: run-with-env <envfile> [-- ...args passed to npx expo start]" >&2
  exit 1
fi

ENV_FILE="$1"
shift

if [[ ! -f "$ENV_FILE" ]]; then
  echo "run-with-env: file not found: $ENV_FILE (cwd: $APP_ROOT)" >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
if [[ -f .env ]]; then
  source .env
fi
source "$ENV_FILE"
set +a

exec npx expo start "$@"
