VITE_API_URL=http://localhost:8000

# For the Docker nginx image (root `docker compose`), leave empty so the browser
# calls same-origin `/api/...` and nginx proxies to the backend (see ``API_PROXY_*`` in ``frontend/Dockerfile``).
# VITE_API_URL=

# Render / other hosts running ``frontend/Dockerfile``: set container env (not Vite) so nginx can proxy:
#   API_PROXY_TARGET=https://YOUR-API.onrender.com
#   API_PROXY_HOST=YOUR-API.onrender.com
